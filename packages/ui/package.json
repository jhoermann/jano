{
  "name": "@jano-editor/ui",
  "version": "1.0.0-alpha.2",
  "description": "Terminal UI library for jano editor",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js"
    },
    "main": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:node:*",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
